{
    "manifest_version": 3,
    "name": "gmail",
    "version": "1.0",
    "description": "checks if email has curse words",
    "action": {
      "default_popup": "popup.html",
      "default_icon": "icon.png"
    },
    "permissions": ["tabs", "activeTab"],
    "host_permissions": ["https://mail.google.com/*"],
    "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
    ]
  }
